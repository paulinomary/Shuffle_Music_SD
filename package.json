{
  "name": "shuffle-music-sd",
  "version": "2.0.1",
  "description": "App de desktop que baralha as músicas de um cartão SD adicionando um número aleatório ao nome, para colunas Bluetooth sem shuffle.",
  "main": "src/main.js",
  "author": "Mariana Paulino",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "test": "node test/shuffle.test.js",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.marianapaulino.shufflemusicsd",
    "productName": "Shuffle Music SD",
    "files": ["src/**/*", "package.json"],
    "extraResources": [{ "from": "resources/fatsort", "to": "fatsort" }],
    "mac": { "target": "dmg", "x64ArchFiles": "Contents/Resources/fatsort" },
    "win": { "target": "nsis" }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}
