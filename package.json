{
  "name": "shuffle-music-sd",
  "version": "3.2.0",
  "description": "App de desktop que baralha a ordem física das músicas de um cartão SD, para colunas Bluetooth sem shuffle.",
  "main": "src/main.js",
  "author": "Mariana Paulino",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "test": "node test/shuffle.test.js",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.marianapaulino.shufflemusicsd",
    "productName": "Shuffle Music SD",
    "files": ["src/**/*", "package.json"],
    "mac": { "target": "dmg" },
    "win": { "target": "nsis" }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}
